# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Database Configuration
# Local without Docker: use your Neon cloud connection string.
# Docker Compose dev with Neon Local: use the local proxy connection string.
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require
DATABASE_NAME=neondb

# Neon Local Driver Configuration
# Use true inside the Docker Compose development app container.
# Leave false or unset for normal host-local development against Neon Cloud.
USE_NEON_LOCAL=false
NEON_LOCAL_HOST=localhost

# JWT Configuration
JWT_SECRET=replace-with-a-long-random-secret

# Arcjet Security Configuration
ARCJET_KEY=replace-with-your-arcjet-key
ARCJET_ENV=development

# Neon API Configuration for Neon Local
NEON_API_KEY=replace-with-your-neon-api-key
NEON_PROJECT_ID=replace-with-your-neon-project-id
PARENT_BRANCH_ID=replace-with-your-parent-branch-id
DELETE_BRANCH=true
